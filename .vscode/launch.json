{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Train: distill (stage 1)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train_distill.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--image-dir",
                "${workspaceFolder}/_tmp_train_data/images",
                "--teacher-checkpoint",
                "${workspaceFolder}/checkpoints/sam_vit_h_4b8939.pth",
                "--output",
                "${workspaceFolder}/checkpoints/distill_stage1.pt",
                "--epochs",
                "1",
                "--batch-size",
                "1",
                "--num-workers",
                "0"
            ]
        },
        {
            "name": "Train: RDLNet (stage 2)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train_rdlnet.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--annotations",
                "${workspaceFolder}/_tmp_train_data/ann.json",
                "--image-root",
                "${workspaceFolder}/_tmp_train_data",
                "--distill-checkpoint",
                "${workspaceFolder}/checkpoints/distill_stage1.pt",
                "--output",
                "${workspaceFolder}/checkpoints/rdlnet.pt",
                "--epochs",
                "1",
                "--batch-size",
                "1",
                "--num-workers",
                "0"
            ]
        },
        {
            "name": "Train: RDLNet (stage 2, scratch backbone)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train_rdlnet.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--annotations",
                "${workspaceFolder}/_tmp_train_data/ann.json",
                "--image-root",
                "${workspaceFolder}/_tmp_train_data",
                "--output",
                "${workspaceFolder}/checkpoints/rdlnet.pt",
                "--epochs",
                "1",
                "--batch-size",
                "1",
                "--num-workers",
                "0"
            ]
        }
    ]
}
